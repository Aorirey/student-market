# Порт сервера
PORT=3000

# DATABASE_URL - строка подключения к PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/database

# Режим работы: 'postgres' или 'sqlite'
DB_MODE=sqlite

# Разрешённые CORS origin (через запятую)
ALLOWED_ORIGINS=http://localhost:3000

# ВКонтакте OAuth (получить на https://dev.vk.com/)
VK_CLIENT_ID=your-app-id
VK_CLIENT_SECRET=your-app-secret
VK_REDIRECT_URI=http://localhost:3000/auth/vk/callback

# Режим окружения: 'development' или 'production'
NODE_ENV=development

# Telegram Bot (создать через @BotFather)
# Бот работает через api.telegram.org — не блокируется в РФ
TELEGRAM_BOT_TOKEN=your-bot-token-here
