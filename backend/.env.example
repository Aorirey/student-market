# Порт сервера
PORT=3000

# DATABASE_URL - строка подключения к PostgreSQL (Neon/Render)
DATABASE_URL=postgresql://user:password@host:port/database

# Режим работы: 'postgres' или 'sqlite'
DB_MODE=sqlite

# Разрешённые CORS origin (через запятую)
ALLOWED_ORIGINS=http://localhost:3000

# Режим окружения: 'development' или 'production'
NODE_ENV=development
