# Порт сервера
PORT=3000

# DATABASE_URL - строка подключения к PostgreSQL (Neon)
# Пример: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:port/database

# Режим работы: 'postgres' или 'sqlite'
DB_MODE=sqlite

# Разрешённые CORS origin (через запятую)
ALLOWED_ORIGINS=http://localhost:3000

# Секретный ключ для сессий (для production используйте случайную строку 32+ символов)
# SESSION_SECRET=your-secret-key-here

# Режим окружения: 'development' или 'production'
NODE_ENV=development
