# Порт сервера
PORT=3000

# DATABASE_URL - строка подключения к PostgreSQL (Neon/Render)
# Пример: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:port/database

# Режим работы: 'postgres' или 'sqlite'
DB_MODE=sqlite

# Разрешённые CORS origin (через запятую)
ALLOWED_ORIGINS=http://localhost:3000

# Telegram Bot Token (получить у @BotFather)
# Нужен для Telegram Login Widget
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Telegram Bot Username (без @) - для виджета авторизации
TELEGRAM_BOT_USERNAME=YourBotUsername

# Режим окружения: 'development' или 'production'
NODE_ENV=development
